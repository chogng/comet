{
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2022",
		"strict": true,
		"noUnusedParameters": true,
		"noUnusedLocals": true,
		"rootDir": "./src",
		"outDir": "./out",
		"sourceMap": true,
		"declaration": true,
		"skipLibCheck": true,
		"types": ["node"],
		"lib": ["ES2022", "DOM"]
	},
	"exclude": ["node_modules", "out", "tools"]
}
