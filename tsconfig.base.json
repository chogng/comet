{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "paths": {
      "app/*": ["./src/*"],
      "base/*": ["./src/ls/base/*"],
      "code/*": ["./src/ls/code/*"],
      "editor/*": ["./src/ls/editor/*"],
      "language/*": ["./build/lib/*"],
      "ls/*": ["./src/ls/*"],
      "platform/*": ["./src/ls/platform/*"],
      "workbench/*": ["./src/ls/workbench/*"]
    },
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  }
}
