{
  "name": "literature-studio",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop studio for reading journal websites and organizing literature.",
  "author": "chogng",
  "main": "dist-electron/code/electron-main/main.js",
  "type": "module",
  "scripts": {
    "predev": "node ./scripts/kill-dev-ports.mjs",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "build:electron": "tsc -p tsconfig.electron.json --noEmit && node ./scripts/build-electron.mjs",
    "build:web": "tsc -p tsconfig.build.json --noEmit && vite build --config vite.web.config.ts",
    "dev:electron:build": "node ./scripts/build-electron.mjs --watch",
    "dev:electron:run": "node ./scripts/dev-electron-runner.mjs",
    "dev:electron": "concurrently -k \"npm:dev:electron:build\" \"npm:dev:electron:run\"",
    "dev:web": "vite --config vite.web.config.ts",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "test:base-common": "node scripts/run-base-common-tests.mjs",
    "test:workbench-browser": "node scripts/run-workbench-browser-tests.mjs",
    "test:editor": "node scripts/run-editor-tests.mjs",
    "test:pdf-selection": "node scripts/run-pdf-selection-tests.mjs",
    "test:library-store": "node scripts/run-library-store-tests.mjs",
    "test:electron-main": "node scripts/run-electron-main-tests.mjs",
    "test:agent": "node scripts/run-agent-tests.mjs",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "dist:win": "npm run build && electron-builder --win nsis portable --x64 --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --x64 --publish never",
    "build": "npm run build:electron && tsc -p tsconfig.build.json --noEmit && vite build",
    "start": "npm run build:electron && node dist-electron/code/electron-main/launch.js dist-electron/code/electron-main/main.js",
    "preview": "vite preview",
    "preview:web": "vite preview --config vite.web.config.ts"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-gapcursor": "^1.4.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.11.0",
    "prosemirror-view": "^1.41.7"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^37.5.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.chogng.literaturestudio",
    "productName": "Literature Studio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/code/electron-main/main.js"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    }
  }
}
